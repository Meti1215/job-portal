generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  JOB_SEEKER
  EMPLOYER
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}